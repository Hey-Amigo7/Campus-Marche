generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

enum EscrowStatus {
  PENDING_PAYMENT
  PAYMENT_INITIALIZED
  PAYMENT_VERIFIED
  ESCROW_HELD
  PROCESSING
  SHIPPED
  DELIVERED
  RELEASE_PENDING
  RELEASED
  DISPUTED
  REFUNDED
  FAILED
}

enum PayoutStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum PayoutMethod {
  MTN_MOMO
  TELECEL_CASH
  AIRTELTIGO_MONEY
  BANK_TRANSFER
}

// ─── Core models ──────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String
  avatar        String   @default("A")
  bio           String?
  verified      Boolean  @default(false)
  phone         String?
  phoneVerified Boolean  @default(false)
  premium       Boolean  @default(false)
  role          UserRole @default(USER)
  canEditEvents Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products           Product[]
  orders             Order[]
  deliveries         Order[]               @relation("DeliveryPerson")
  reviews            Review[]
  savedItems         SavedItem[]
  business           BusinessProfile?
  payments           PaymentTransaction[]
  notifications      Notification[]
  reports            Report[]              @relation("ReportedBy")
  reportedIn         Report[]              @relation("Reported")
  adminLogs          AdminLog[]
  passwordResets     PasswordResetToken[]
  emailVerifications EmailVerification[]
  otpVerifications   OtpVerification[]
  sentMessages       Message[]             @relation("SentMessages")
  conversationsAsA   Conversation[]        @relation("ConversationParticipantA")
  conversationsAsB   Conversation[]        @relation("ConversationParticipantB")
  subscription       Subscription?
  wallet             Wallet?
  transferRecipients TransferRecipient[]
  payouts            Payout[]
  sellerOrders       Order[]               @relation("SellerOrders")
}

model BusinessProfile {
  id           String   @id @default(cuid())
  name         String
  type         String
  description  String?
  location     String
  phone        String?
  momoProvider String?
  momoPhone    String?
  verified     Boolean  @default(false)
  premium      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id          String    @id @default(cuid())
  title       String
  description String?
  price       Float
  condition   String    @default("Good")
  location    String
  imageUrl    String?
  imageStyle  String    @default("art-laptop")
  featured    Boolean   @default(false)
  boosted     Boolean   @default(false)
  negotiable  Boolean   @default(false)
  active      Boolean   @default(true)
  category    String?
  listingType String    @default("product")
  soldAt      DateTime?
  tags        String    @default("")
  views       Int       @default(0)
  postedAt    DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sellerId      String
  seller        User           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orders        Order[]
  reviews       Review[]
  savedItems    SavedItem[]
  conversations Conversation[]
  reports       Report[]

  @@index([sellerId])
  @@index([category])
  @@index([title])
  @@index([featured])
  @@index([boosted])
  @@index([active])
  @@index([postedAt])
}

// ─── Orders & Payments ────────────────────────────────────────────────────────

model Order {
  id                  String       @id @default(cuid())
  // Lifecycle status (delivery stage)
  status              String       @default("Awaiting payment")
  // Payment/escrow state machine
  escrowStatus        EscrowStatus @default(PENDING_PAYMENT)
  // Kept for backward-compat; always synced with escrowStatus
  paymentStatus       String       @default("Unpaid")
  // Financial fields
  price               Float
  totalAmount         Float        @default(0)
  platformFee         Float        @default(0)
  sellerAmount        Float        @default(0)
  // Paystack reference for the primary payment
  paymentReference    String?
  // Delivery
  deliveryAddress     String?
  deliveryPhone       String?
  deliveryPersonId    String?
  deliveryConfirmedAt DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  buyerId        String
  buyer          User                 @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId       String?
  seller         User?                @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: SetNull)
  productId      String
  product        Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  payments       PaymentTransaction[]
  tracking       DeliveryTracking?
  deliveryPerson User?                @relation("DeliveryPerson", fields: [deliveryPersonId], references: [id], onDelete: SetNull)
  payouts        Payout[]
  revenue        PlatformRevenue?

  @@index([buyerId])
  @@index([sellerId])
  @@index([productId])
  @@index([escrowStatus])
}

model PaymentTransaction {
  id               String    @id @default(cuid())
  provider         String    @default("paystack")
  reference        String    @unique
  status           String    @default("Pending")
  amount           Float
  currency         String    @default("GHS")
  authorizationUrl String?
  accessCode       String?
  paidAt           DateTime?
  verifiedAt       DateTime?
  metadata         String    @default("")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([userId])
  @@index([reference])
}

// ─── Seller Wallet ────────────────────────────────────────────────────────────

model Wallet {
  id               String   @id @default(cuid())
  availableBalance Float    @default(0)
  pendingBalance   Float    @default(0)
  totalEarnings    Float    @default(0)
  totalWithdrawn   Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Payouts ──────────────────────────────────────────────────────────────────

model TransferRecipient {
  id            String   @id @default(cuid())
  recipientCode String   @unique
  type          String   @default("mobile_money")
  bankName      String?
  accountNumber String?
  momoPhone     String?
  momoNetwork   String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  sellerId String
  seller   User   @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
}

model Payout {
  id                String       @id @default(cuid())
  amount            Float
  payoutMethod      PayoutMethod @default(MTN_MOMO)
  transferReference String?
  transferCode      String?
  recipientCode     String?
  status            PayoutStatus @default(PENDING)
  failureReason     String?
  approvedAt        DateTime?
  processedAt       DateTime?
  completedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  sellerId String
  seller   User   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orderId  String?
  order    Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([sellerId])
  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

// ─── Platform Revenue Ledger ──────────────────────────────────────────────────

model PlatformRevenue {
  id           String   @id @default(cuid())
  feeAmount    Float
  feePercent   Float    @default(0)
  feeFixed     Float    @default(0)
  totalAmount  Float
  sellerAmount Float
  recordedAt   DateTime @default(now())

  orderId String  @unique
  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([recordedAt])
}

// ─── Webhook Idempotency Log ──────────────────────────────────────────────────

model WebhookLog {
  id        String   @id @default(cuid())
  provider  String   @default("paystack")
  eventType String
  reference String?
  payload   String
  verified  Boolean  @default(false)
  processed Boolean  @default(false)
  error     String?
  createdAt DateTime @default(now())

  @@index([reference])
  @@index([eventType])
  @@index([createdAt])
}

// ─── Messaging ────────────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participantAId String
  participantA   User     @relation("ConversationParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantBId String
  participantB   User     @relation("ConversationParticipantB", fields: [participantBId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  messages Message[]

  @@unique([participantAId, participantBId, productId])
  @@index([participantAId])
  @@index([participantBId])
}

model Message {
  id        String   @id @default(cuid())
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
}

// ─── Reviews & Saved ─────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  rating    Float
  comment   String?
  author    String
  createdAt DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productId])
}

model SavedItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
}

// ─── Events ───────────────────────────────────────────────────────────────────

model CampusEvent {
  id          String   @id @default(cuid())
  title       String
  description String
  location    String
  eventDate   DateTime
  category    String   @default("Campus update")
  opportunity String?
  imageUrl    String?
  featured    Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Notifications, Reports, Logs ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

model Report {
  id          String   @id @default(cuid())
  reason      String
  description String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reporterId     String
  reporter       User     @relation("ReportedBy", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUserId String?
  reportedUser   User?    @relation("Reported", fields: [reportedUserId], references: [id], onDelete: SetNull)
  productId      String?
  product        Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([reporterId])
  @@index([status])
}

model AdminLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())

  adminId String
  admin   User   @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([entity])
}

// ─── Auth tokens ──────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model EmailVerification {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model OtpVerification {
  id        String   @id @default(cuid())
  code      String
  purpose   String   @default("email")
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([purpose])
}

// ─── Delivery & Contact ───────────────────────────────────────────────────────

model DeliveryTracking {
  id        String   @id @default(cuid())
  latitude  Float
  longitude Float
  heading   Float?
  speed     Float?
  updatedAt DateTime @updatedAt

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now())

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Subscription {
  id        String    @id @default(cuid())
  plan      String    @default("free")
  status    String    @default("active")
  startsAt  DateTime  @default(now())
  expiresAt DateTime?
  reference String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}
