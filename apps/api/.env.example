# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
# Local PostgreSQL:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/campus_marche?schema=public"
#
# Supabase (recommended for production):
# 1. Create a project at https://supabase.com/dashboard
# 2. Go to Project Settings → Database → Connection string (URI)
# 3. Copy the connection string and replace [YOUR-PASSWORD]:
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
# Note: add ?pgbouncer=true only if using the connection pooler (port 6543 vs 5432)

# ─────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET="replace-with-at-least-32-random-characters-use-openssl"
JWT_EXPIRES_IN="7d"
BCRYPT_SALT_ROUNDS="12"

# ─────────────────────────────────────────────
# Admin bootstrap (REQUIRED before first deploy)
# ─────────────────────────────────────────────
# POST /auth/bootstrap-admin creates the first admin account.
# It requires ADMIN_SETUP_KEY in the request body — this key is NEVER exposed publicly.
# Generate with: openssl rand -hex 24
# After the admin is created you don't need this endpoint again; keep the key secret.
ADMIN_SETUP_KEY="generate-with-openssl-rand-hex-24"
ADMIN_EMAIL="admin@campus-marche.com"
ADMIN_PASSWORD="change-me-to-a-strong-password-min-12-chars"

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT="3002"
NODE_ENV="development"

# ─────────────────────────────────────────────
# CORS & URLs
# ─────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:3002"

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
THROTTLE_TTL="60000"
THROTTLE_LIMIT="100"
AUTH_THROTTLE_TTL="60000"
AUTH_THROTTLE_LIMIT="5"

# ─────────────────────────────────────────────
# Paystack (Ghana payments)
# ─────────────────────────────────────────────
# Get test keys at https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=""
PAYSTACK_CALLBACK_URL="http://localhost:3000/orders"

# ─────────────────────────────────────────────
# Email / SMTP
# ─────────────────────────────────────────────
# Used for: OTP verification, password reset, contact form forwarding.
# If unset, all emails are logged to console (dev mode).
#
# ── Gmail (easiest) ──────────────────────────
# 1. Enable 2-Factor Authentication on your Gmail account
# 2. Go to Google Account → Security → App passwords
# 3. Create an app password (name it "Campus Marche")
# 4. Use the 16-character App Password as SMTP_PASS (not your login password)
#
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS=""
# The address that appears as the sender on all emails
SMTP_FROM="Campus Marche <your-gmail@gmail.com>"
# Where contact form submissions are delivered (defaults to SMTP_FROM if unset)
CONTACT_EMAIL="your-gmail@gmail.com"
#
# ── Resend (recommended for production) ──────
# Sign up free at https://resend.com — 3 000 emails/month on free tier
# Add your domain, then use these settings:
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT="587"
# SMTP_USER="resend"
# SMTP_PASS="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# SMTP_FROM="Campus Marche <noreply@yourdomain.com>"
# CONTACT_EMAIL="yourteam@yourdomain.com"

# ─────────────────────────────────────────────
# SMS / Arkesel (optional — logs to console if unset)
# ─────────────────────────────────────────────
# Used for phone number OTP verification. Sign up at https://arkesel.com
# ARKESEL_API_KEY is the only required field; SMS_SENDER_ID defaults to "CampusMarche"
ARKESEL_API_KEY=""
SMS_SENDER_ID="CampusMarche"

# ─────────────────────────────────────────────
# Marketplace Commission
# ─────────────────────────────────────────────
# Platform keeps MARKETPLACE_FEE_PERCENT % + MARKETPLACE_FEE_FLAT GHS per order.
# Seller receives: total_amount - platform_fee
# Example: 1% on GHS 100 → GHS 1 platform fee, GHS 99 to seller.
MARKETPLACE_FEE_PERCENT="1"
MARKETPLACE_FEE_FLAT="0"

# ─────────────────────────────────────────────
# Payout Behavior
# ─────────────────────────────────────────────
# true  = auto-initiate transfer when buyer confirms delivery (good for dev/testing)
# false = admin must approve payouts before transfer fires (recommended for production)
PAYOUT_AUTO_APPROVE="true"

# ─────────────────────────────────────────────
# Smart listing images — Unsplash (optional but highly recommended)
# ─────────────────────────────────────────────
# When a seller creates a listing without uploading a photo, the API searches
# Unsplash using the product title + category and stores the best match permanently.
# Free tier: 50 req/hr (Demo). Upgrade to Production for unlimited.
# 1. Create an account at https://unsplash.com/developers
# 2. Create a new application → copy the "Access Key" below
UNSPLASH_ACCESS_KEY=""

# ─────────────────────────────────────────────
# File uploads (optional — defaults to ./uploads/)
# ─────────────────────────────────────────────
# Absolute path to the directory where uploaded images are stored.
# In production, point this to a persistent volume mount.
# UPLOAD_DIR="/var/data/campus-marche/uploads"
