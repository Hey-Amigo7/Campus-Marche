# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, or local)
DATABASE_URL="postgresql://postgres:password@localhost:5432/campus_marche?schema=public"

# ─────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET="replace-with-at-least-32-random-characters-use-openssl"
JWT_EXPIRES_IN="7d"
BCRYPT_SALT_ROUNDS="12"

# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT="3002"
NODE_ENV="development"

# ─────────────────────────────────────────────
# CORS & URLs
# ─────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:3002"

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
THROTTLE_TTL="60000"
THROTTLE_LIMIT="100"
AUTH_THROTTLE_TTL="60000"
AUTH_THROTTLE_LIMIT="5"

# ─────────────────────────────────────────────
# Paystack (Ghana payments)
# ─────────────────────────────────────────────
# Get test keys at https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=""
PAYSTACK_CALLBACK_URL="http://localhost:3000/orders"

# ─────────────────────────────────────────────
# Email / SMTP (optional — logs to console if unset)
# ─────────────────────────────────────────────
# Works with any SMTP provider: SendGrid, Mailgun, Gmail, Resend, etc.
# SendGrid example: SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey SMTP_PASS=<your-api-key>
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@campusmarche.com"

# ─────────────────────────────────────────────
# SMS / Arkesel (optional — logs to console if unset)
# ─────────────────────────────────────────────
# Used for phone number OTP verification. Sign up at https://arkesel.com
# ARKESEL_API_KEY is the only required field; SMS_SENDER_ID defaults to "CampusMarche"
ARKESEL_API_KEY=""
SMS_SENDER_ID="CampusMarche"

# ─────────────────────────────────────────────
# File uploads (optional — defaults to ./uploads/)
# ─────────────────────────────────────────────
# Absolute path to the directory where uploaded images are stored.
# In production, point this to a persistent volume mount.
# UPLOAD_DIR="/var/data/campus-marche/uploads"
