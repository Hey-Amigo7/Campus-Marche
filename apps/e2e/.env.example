# E2E Test Environment
# Copy to .env and fill in real values before running tests

# Dev server URLs (must be running before tests start)
E2E_BASE_URL=http://localhost:3000
E2E_API_URL=http://localhost:3002

# Admin credentials (from apps/api/.env ADMIN_EMAIL / ADMIN_PASSWORD)
E2E_ADMIN_EMAIL=admin@campus-marche.com
E2E_ADMIN_PASSWORD=Admin@123!

# A real registered & verified user account for authenticated-flow tests.
# Create one manually via the registration flow, then fill in here.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
